{
  // Electron's main process cannot run TypeScript directly (Electron routes .ts
  // through Node's experimental type-stripping loader, where the `electron`
  // builtin is not injected). So the main process + preload are compiled to
  // CommonJS .cjs here and loaded from desktop/electron/out by Electron.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": false,
    "lib": ["ES2023"],
    "types": ["node"],
    "rootDir": "desktop/electron",
    "outDir": "desktop/electron/out",
    "sourceMap": true
  },
  "include": ["desktop/electron/*.cts"],
  "exclude": ["desktop/electron/out"]
}
