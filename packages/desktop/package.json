{
  "name": "@nav/desktop",
  "version": "1.0.0",
  "private": true,
  "main": "out/main-process/main.js",
  "scripts": {
    "dev": "pnpm run build:main && concurrently -k -n vite,electron \"vite --host 127.0.0.1\" \"wait-on tcp:127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "pnpm run build:main && tsc -p tsconfig.renderer.json && vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "test": "node --test"
  },
  "type": "module",
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "26.0.1",
    "concurrently": "10.0.3",
    "cross-env": "10.1.0",
    "electron": "42.5.0",
    "tailwindcss": "^4.3.1",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "wait-on": "9.0.10"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "radix-ui": "^1.6.0",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  }
}
