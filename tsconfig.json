{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./desktop/electron/renderer/src/*"]
    }
  },
  "include": [
    "desktop/electron/**/*.ts",
    "desktop/electron/**/*.tsx",
    "desktop/electron/**/*.cts",
    "tests/**/*.cts"
  ],
  "exclude": ["desktop/electron/out", "desktop/electron/renderer/dist"]
}
