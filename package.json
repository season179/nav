{
  "name": "nav",
  "private": true,
  "description": "Learning project for building a coding agent.",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24.16.0 <25",
    "pnpm": ">=11.0.0 <12"
  },
  "scripts": {
    "dev": "pnpm run electron:dev",
    "reset-data": "node scripts/reset-data.mjs",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.main.json --noEmit && pnpm --dir backend run typecheck",
    "main:build": "tsc -p tsconfig.main.json",
    "renderer:build": "vite build --config desktop/electron/renderer/vite.config.ts",
    "electron:dev": "pnpm --dir backend run build && pnpm run main:build && pnpm run renderer:build && electron desktop/electron/out/main.cjs",
    "electron:smoke": "pnpm --dir backend run build && pnpm run main:build && pnpm run renderer:build && electron desktop/electron/out/main.cjs --smoke",
    "check:electron": "pnpm run typecheck && pnpm --dir backend run build && pnpm run main:build && pnpm run renderer:build && node --test tests/*.test.cts",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.2.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.211",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-pacer": "^0.22.1",
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-query-devtools": "^5.101.1",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-store": "^0.11.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.3",
    "@tanstack/store": "^0.11.0",
    "ai": "^6.0.209",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dompurify": "^3.4.5",
    "lucide-react": "^1.21.0",
    "marked": "^18.0.4",
    "nanoid": "^5.1.15",
    "radix-ui": "^1.6.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shiki": "^4.2.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tokenlens": "^1.3.1",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.6"
  }
}
