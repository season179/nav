{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "desktop/**",
      "packages/desktop/**",
      "packages/agent-server/**",
      "scripts/**",
      "tests/**/*.cts",
      "!!.nav",
      "!desktop/electron/out",
      "!desktop/electron/renderer/dist",
      "!desktop/electron/renderer/vendor",
      "!packages/desktop/dist",
      "!packages/desktop/out",
      "!packages/desktop/src/components/ai-elements",
      "!packages/desktop/src/components/ui",
      "!packages/desktop/src/lib/utils.ts",
      "!packages/desktop/src/styles.css",
      "!packages/agent-server/dist"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  }
}
